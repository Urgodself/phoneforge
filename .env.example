# PhoneForge environment template — copy to .env and fill in.
# Never commit the real .env file.

# OpenAI key for identity generation + SMS code extraction + captcha vision.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# OpenAI models (override if needed).
PHONEFORGE_LLM_TEXT_MODEL=gpt-4o-mini
PHONEFORGE_LLM_VISION_MODEL=gpt-4o

# Proxy source. Two modes:
#   - "local"  : read from /Users/aleksej/Desktop/Nothing/yt-manager/data/ytmanager.db
#   - "ssh"    : read from VPS via `ssh ytm-vps`
PHONEFORGE_PROXY_SOURCE=ssh
PHONEFORGE_PROXY_SSH_HOST=ytm-vps
PHONEFORGE_PROXY_VPS_DB=/root/yt-manager/data/ytmanager.db
PHONEFORGE_PROXY_LOCAL_DB=/Users/aleksej/Desktop/Nothing/yt-manager/data/ytmanager.db

# When fetching from Smartproxy template, force area=US.
PHONEFORGE_PROXY_FORCE_AREA=US

# Camoufox launch defaults.
PHONEFORGE_HEADLESS=false
PHONEFORGE_LAUNCH_TIMEOUT_MS=90000

# Manual mode for TextNow signup — set true to pause at signup form for human completion.
PHONEFORGE_MANUAL_SIGNUP=false

# ──────────── 5sim.net (primary SMS-API provider) ────────────
# Get a Bearer token from https://5sim.net/profile (after signup + top-up).
FIVESIM_API_KEY=eyJhbGciOiJSUzUxMi...REPLACE_ME

# 5sim country slug (lowercase: 'usa', 'russia', 'germany', etc.).
FIVESIM_COUNTRY=usa
# Operator (any | verizon | att | tmobile | ...). 'any' = let 5sim pick.
FIVESIM_OPERATOR=any
# Override the upstream base URL only if you're behind a proxy that needs it.
FIVESIM_BASE_URL=https://5sim.net/v1
# Polling cadence for `phoneforge wait` (seconds).
FIVESIM_POLL_INTERVAL_S=5.0
# How long `phoneforge wait` waits before declaring NO_CODE (seconds).
FIVESIM_TIMEOUT_S=300
# Per-request HTTP timeout.
FIVESIM_HTTP_TIMEOUT_S=30.0
